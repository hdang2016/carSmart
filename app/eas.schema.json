{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./eas.schema.json",
  "title": "Local EAS Config Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "cli": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string" },
        "appVersionSource": { "type": "string", "enum": ["local", "remote"] }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "submit": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": ["build"]
}
